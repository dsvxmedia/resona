# Vercel AI Gateway — used for all model calls (Claude Sonnet/Haiku, OpenAI embeddings)
# routed through gateway string IDs like "anthropic/claude-sonnet-5".
# Get a key: https://vercel.com/d?to=%2F%5Bteam%5D%2F%7E%2Fai%2Fapi-keys
# On Vercel deployments this can also resolve automatically via OIDC (vercel link).
AI_GATEWAY_API_KEY=

# Direct-provider fallback (optional) — only needed if not using the AI Gateway.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Opik (optional) — LLM/agent tracing. Leave unset to run without tracing.
# OPIK_API_KEY=
